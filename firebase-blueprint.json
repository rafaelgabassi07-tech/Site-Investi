{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Dados do perfil do usuário",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Lançamento de compra ou venda de ativo",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "ticker": { "type": "string" },
        "type": { "type": "string", "enum": ["BUY", "SELL"] },
        "assetType": { "type": "string", "enum": ["ACAO", "FII", "ETF", "BDR", "CRIPT", "RF"] },
        "quantity": { "type": "number" },
        "price": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "broker": { "type": "string" }
      },
      "required": ["userId", "ticker", "type", "quantity", "price", "date"]
    },
    "PortfolioItem": {
      "title": "PortfolioItem",
      "description": "Resumo de um ativo na carteira",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "ticker": { "type": "string" },
        "assetType": { "type": "string" },
        "totalQuantity": { "type": "number" },
        "averagePrice": { "type": "number" },
        "totalInvested": { "type": "number" }
      },
      "required": ["userId", "ticker"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Dados do usuário"
    },
    "/users/{userId}/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Histórico de transações do usuário"
    },
    "/users/{userId}/portfolio/{ticker}": {
      "schema": "PortfolioItem",
      "description": "Ativos consolidados na carteira"
    }
  }
}
